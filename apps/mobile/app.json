{
  "expo": {
    "name": "ERTANSA Denetim",
    "slug": "ertansa-audit",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ertansa-audit",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2E7D32"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ertansa.audit",
      "infoPlist": {
        "NSCameraUsageDescription": "Denetim sirasinda fotograf cekmek icin kamera erisimi gereklidir.",
        "NSLocationWhenInUseUsageDescription": "Denetim konumunu dogrulamak icin konum erisimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "Galeriden fotograf secmek icin erisim gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#2E7D32"
      },
      "package": "com.ertansa.audit",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-location",
      "expo-notifications",
      "expo-image-picker",
      "expo-secure-store",
      "expo-sqlite",
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "fe15d761-62c6-4ba0-912a-a40d5556c6ed"
      }
    }
  }
}
